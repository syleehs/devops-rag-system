# DevOps RAG System - Environment Variables

# Anthropic API (REQUIRED)
ANTHROPIC_API_KEY=your-api-key-here

# PostgreSQL
DB_NAME=devops_rag
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# AWS (optional)
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Application
ENVIRONMENT=development
LOG_LEVEL=INFO
API_PORT=8000
